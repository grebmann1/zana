{
  "name": "@zana-ai/core",
  "version": "0.3.0",
  "description": "Zana engine — multi-agent orchestration, scheduling, persistence, and module system. Used by @zana-ai/mcp.",
  "main": "dist/src/index.js",
  "bin": {
    "zana-daemon": "./dist/bin/daemon.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.js",
    "start": "node dist/bin/daemon.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "minimatch": "^10.0.0"
  },
  "peerDependencies": {
    "@zana-ai/swarm": "0.3.0",
    "@zana-ai/extras": "0.3.0",
    "@zana-ai/intelligence": "0.3.0",
    "@zana-ai/work": "0.3.0",
    "@zana-ai/server": "0.3.0"
  },
  "peerDependenciesMeta": {
    "@zana-ai/swarm": {
      "optional": true
    },
    "@zana-ai/extras": {
      "optional": true
    },
    "@zana-ai/intelligence": {
      "optional": true
    },
    "@zana-ai/work": {
      "optional": true
    },
    "@zana-ai/server": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "node-pty": "^1.1.0"
  },
  "files": [
    "dist/",
    "profiles/",
    "modules/"
  ],
  "keywords": [
    "claude",
    "agent",
    "orchestrator",
    "mcp",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grebmann1/zana.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/grebmann1/zana#readme"
}
