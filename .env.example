# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# npm granular automation token with read/write on the @zana-ai scope.
# Create at npmjs.com → Access Tokens → Generate → Granular Access Token
# (select the @zana-ai scope, Read and write). Granular tokens bypass 2FA,
# so the release script can publish all packages unattended.
NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
