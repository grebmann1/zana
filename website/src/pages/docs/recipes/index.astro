---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocsSubnav from '../../../components/DocsSubnav.astro';
import MythicDivider from '../../../components/MythicDivider.astro';
import { link } from '../../../lib/url';

const recipes = [
  {
    href: '/docs/recipes/ticket-worker/',
    title: 'Ticket-driven worker',
    body: 'Create → claim → spawn worker → complete. Every transition is auditable on the ticket record.',
    test: 'scripts/qa/run-ticket-live.sh — 7/7 passing',
  },
  {
    href: '/docs/recipes/scheduled-agent/',
    title: 'Recurring agent on a schedule',
    body: 'Drop a YAML in .zana/scheduler/, reload, trigger. The MCP tool returns immediately on spawn — agent runs detached on the daemon.',
    test: 'scripts/qa/run-scheduler-agent-live.sh — 4/4 passing',
  },
  {
    href: '/docs/recipes/autopilot/',
    title: 'Goal-driven autopilot',
    body: 'Submit a goal with ordered steps and success criteria. Autopilot runs each step, an evaluator judges, then settles or iterates.',
    test: 'scripts/qa/run-autopilot-live.sh — 6/6 passing',
  },
  {
    href: '/docs/recipes/deliberation/',
    title: 'Deliberation (with optional auto-judge)',
    body: 'Multi-voter consensus with dissent preserved verbatim. Pass escalationStrategy: "judge" to settle deadlocks without a human.',
    test: 'scripts/qa/run-runtime.sh — 2/2 passing',
  },
];
---

<BaseLayout
  title="Docs · Recipes"
  description="Copy-paste end-to-end examples for tickets, schedules, autopilot, and deliberation — each mirrored by a live Claude integration test."
>
  <DocsSubnav />

  <section class="container-zana py-16">
    <p class="ornament text-xs text-gold">— recipes —</p>
    <h1 class="mt-3 font-display text-5xl text-forest md:text-6xl">End-to-end recipes.</h1>
    <p class="mt-6 max-w-2xl text-lg text-moss leading-relaxed">
      Each recipe walks one primitive end-to-end with literal MCP arguments
      and the actual returns. Every one of them is mirrored by a real-Claude
      smoke test under <code class="rounded bg-parchment px-1.5 py-0.5">scripts/qa/</code> —
      no mocks. If a recipe drifts, the test fails.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {recipes.map((r) => (
        <a
          href={link(r.href)}
          class="group block rounded-2xl border border-forest/15 bg-cream/60 p-6 transition hover:border-gold hover:bg-cream hover:shadow-md"
        >
          <h2 class="font-display text-2xl text-forest group-hover:text-berry">{r.title}</h2>
          <p class="mt-3 text-moss leading-relaxed">{r.body}</p>
          <p class="mt-4 text-xs uppercase tracking-wider text-gold">{r.test}</p>
        </a>
      ))}
    </div>

    <div class="mt-16">
      <MythicDivider />
      <div class="mt-10 grid gap-8 md:grid-cols-2 md:items-start">
        <div>
          <h2 class="font-display text-3xl text-forest">Run the live tests yourself</h2>
          <p class="mt-3 text-moss leading-relaxed">
            Every recipe above is exercised by a real-Claude smoke test. They
            cost real tokens (no mocks) but are hermetic — temp workspace +
            isolated daemon registry.
          </p>
        </div>
        <pre class="rounded-xl border border-forest/15 bg-ink text-cream/90 p-5 text-xs leading-relaxed overflow-x-auto"><code>{`# preconditions: \`claude\` CLI on PATH and logged in, repo built
npm run build

bash scripts/qa/run-runtime.sh                 # oneshot + deliberation
bash scripts/qa/run-scheduler-agent-live.sh    # schedule fires real worker
bash scripts/qa/run-ticket-live.sh             # ticket lifecycle
bash scripts/qa/run-autopilot-live.sh          # goal-driven loop

# or all four
bash scripts/qa/run-live-all.sh`}</code></pre>
      </div>
    </div>

    <div class="mt-16">
      <h2 class="font-display text-2xl text-forest">More primitives</h2>
      <p class="mt-3 text-moss leading-relaxed">
        Beyond the four headline recipes, the full
        <a href="https://github.com/grebmann1/zana/blob/main/docs/RECIPES.md" target="_blank" rel="noopener noreferrer" class="text-forest hover:text-berry font-semibold">RECIPES.md</a>
        covers every primitive with literal MCP arguments — teams, sprints, workflows, vector memory, channels, profiles, skills, checkpoints, multi-daemon swarm, validated spawn, artifacts, module config.
      </p>
    </div>
  </section>
</BaseLayout>
