---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PillarCard from '../components/PillarCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CodeBlock from '../components/CodeBlock.astro';
import MythicDivider from '../components/MythicDivider.astro';

const pillars = [
  {
    glyph: 'orchestrate' as const,
    title: 'Orchestrate',
    body: 'Spawn specialized agents — architect, coder, tester, reviewer — and coordinate them with named messaging. You plan; they implement.',
  },
  {
    glyph: 'deliberate' as const,
    title: 'Deliberate',
    body: 'Multi-voter review with a verdict and an audit trail. Dissent preserved verbatim. When the council deadlocks, an opt-in judge agent settles it — high-risk still routes to a human.',
  },
  {
    glyph: 'automate' as const,
    title: 'Automate',
    body: 'Goal-driven autopilot loops, YAML-scheduled work, and event-bus replay. Set the criteria; let the council pursue them.',
  },
];

const features = [
  { tag: 'Agents', title: '18 built-in profiles', body: 'api-designer, architect, backend-dev, code-reviewer, debugger, doc-generator, frontend-dev, full-auto-coder, judge, orchestrator, performance-engineer, researcher, security-reviewer, slack-notifier, swarm-master, swarm-orchestrator, test-writer, ux-designer.' },
  { tag: 'Teams', title: 'Pipeline · fan-out · supervisor', body: 'Compose topologies for sequential dependencies, independent parallel work, or ongoing coordination.' },
  { tag: 'Tickets', title: 'The unit of dispatch', body: 'Independent, small, verifiable work items — fits inside one agent\'s context, plus margin for tools and tests.' },
  { tag: 'Deliberation', title: 'Multi-voter consensus', body: 'Run security-reviewer, performance-engineer, and architect on a decision. Get a synthesized verdict with dissent intact.' },
  { tag: 'Schedules', title: 'YAML — daemon or /loop', body: 'One YAML schema, two execution paths: heavyweight daemon (cron + interval) or lightweight /loop (no daemon required).' },
  { tag: 'Runtime', title: 'Pluggable agent runtime', body: 'A RuntimeAdapter interface lets Zana drive Claude Code spawning, the Vercel AI SDK, or any other host the same way.' },
  { tag: 'MCP', title: '91 tools, one server', body: 'Agent spawn, ticket management, profiles, skills, memory, event bus, scheduling — exposed to any MCP-aware tool.' },
  { tag: 'Plugins', title: 'Two slash-command bundles', body: '`zana@zana-marketplace` ships orchestration. `zana-loop@zana-marketplace` ships daemon-free scheduling.' },
];
---

<BaseLayout
  title="Zana"
  description="Zana is a multi-agent orchestrator for Claude Code. Spawn a council of specialists, coordinate their work, and ship — all from one conversation."
>
  <Hero />

  <!-- What is Zana -->
  <section class="container-zana py-16">
    <MythicDivider />
    <div class="mt-10 grid gap-10 md:grid-cols-[1fr_2fr] md:gap-16">
      <h2 class="font-display text-4xl text-forest">What is Zana?</h2>
      <div class="text-lg leading-relaxed text-ink/85">
        <p>
          Zana is a long-lived daemon that exposes an
          <abbr title="Model Context Protocol">MCP</abbr> server, letting a
          single conversation in Claude Code spawn, supervise, and synthesize
          the work of many specialized worker agents.
        </p>
        <p class="mt-4">
          You become the executive coordinator. Workers implement. Zana keeps
          the loop honest about progress.
        </p>
      </div>
    </div>
  </section>

  <!-- Three Pillars -->
  <section class="relative py-16 bg-parchment/40">
    <div class="container-zana">
      <p class="ornament text-xs text-gold">— three pillars —</p>
      <h2 class="mt-3 font-display text-4xl text-forest">A different way to build with agents.</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {pillars.map((p) => (
          <PillarCard glyph={p.glyph} title={p.title} body={p.body} />
        ))}
      </div>
    </div>
  </section>

  <!-- Code preview -->
  <section class="container-zana py-20">
    <div class="grid gap-12 md:grid-cols-2 md:items-center">
      <div>
        <p class="ornament text-xs text-gold">— a real first session —</p>
        <h2 class="mt-3 font-display text-4xl text-forest">From install to a worker on a ticket — in three calls.</h2>
        <p class="mt-4 text-moss leading-relaxed">
          Zana ships as an MCP server you wire into Claude Code. After install
          you call <code class="rounded bg-parchment px-1.5 py-0.5 text-sm text-ink">zana_*</code>
          tools straight from Claude. The transcript on the right is the
          ticket-driven worker recipe — every line is run end-to-end by
          <code class="rounded bg-parchment px-1.5 py-0.5 text-sm text-ink">scripts/qa/run-ticket-live.sh</code>
          against real Claude (7/7 passing).
        </p>
        <a href="/docs/" class="mt-6 inline-flex text-forest font-medium underline-offset-4 hover:underline">
          Read the full quickstart →
        </a>
      </div>
      <div class="space-y-4">
        <CodeBlock caption="1 · install (node 20+)" lang="bash">{`# fastest — from npm
npm install -g @zana-ai/mcp

# or full repo + slash-command plugins
git clone https://github.com/grebmann1/zana.git
cd zana && bash scripts/install.sh
claude plugin marketplace add "$(pwd)"
claude plugin install zana@zana-marketplace
claude plugin install zana-loop@zana-marketplace`}</CodeBlock>
        <CodeBlock caption="2 · ticket → worker → done (real MCP)" lang="text">{`zana_ticket_create({
  title: "Confirm PONG", priority: "low",
  description: "Reply with PONG to confirm."
})
// → { id: "tkt_abc", status: "backlog" }

zana_spawn_agent({ profileId: "researcher",
  prompt: "Reply with the single word: PONG" })
// → { agentId: "ag_42" }

zana_ticket_complete({ ticketId: "tkt_abc",
  resultSummary: "Worker confirmed: PONG" })
// → { ok: true, status: "done" }`}</CodeBlock>
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="relative py-20 bg-parchment/40">
    <div class="container-zana">
      <p class="ornament text-xs text-gold">— what's inside —</p>
      <h2 class="mt-3 font-display text-4xl text-forest">Primitives, not just prompts.</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard tag={f.tag} title={f.title} body={f.body} />
        ))}
      </div>
      <div class="mt-10">
        <a href="/features/" class="btn-ghost">Explore all features</a>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="container-zana py-24">
    <div class="relative overflow-hidden rounded-3xl border border-gold/30 bg-gradient-to-br from-cream via-parchment to-gold-soft/40 p-10 md:p-16">
      <div class="relative max-w-2xl">
        <h2 class="font-display text-4xl text-forest md:text-5xl">Stop context-switching.</h2>
        <p class="mt-4 text-lg text-ink/80">
          Spawn a code-review team. Run a nightly test audit. Break a refactor
          into parallel tickets. All from one place.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/docs/" class="btn-primary">Get started</a>
          <a href="https://github.com/grebmann1/zana" target="_blank" rel="noopener noreferrer" class="btn-ghost">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
