---
const links = [
  { href: '/how-it-works/', label: 'How it works' },
  { href: '/features/', label: 'Features' },
  { href: '/docs/', label: 'Docs' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 border-b border-forest/10 bg-cream/85 backdrop-blur">
  <div class="container-zana flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 group" aria-label="Zana home">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path d="M16 3 L21 11 L29 13 L23 19 L25 28 L16 23 L7 28 L9 19 L3 13 L11 11 Z"
              fill="none" stroke="#C9A961" stroke-width="1.5" stroke-linejoin="round" />
        <circle cx="16" cy="16" r="2" fill="#C9A961" class="animate-glow" />
      </svg>
      <span class="font-display text-xl font-semibold text-forest tracking-tight">zana</span>
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'text-sm font-medium transition',
            path.startsWith(l.href) ? 'text-forest' : 'text-moss hover:text-forest',
          ]}
        >
          {l.label}
        </a>
      ))}
      <a
        href="https://github.com/grebmann1/zana"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary !py-2 !px-4 text-sm"
      >
        GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M7 17 L17 7 M9 7 H17 V15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </a>
    </nav>

    <details class="md:hidden">
      <summary class="list-none cursor-pointer p-2" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="#2D5F3F" stroke-width="2" stroke-linecap="round" />
        </svg>
      </summary>
      <div class="absolute left-0 right-0 top-16 border-b border-forest/10 bg-cream px-6 py-4">
        <ul class="space-y-3">
          {links.map((l) => (
            <li><a href={l.href} class="block text-forest font-medium">{l.label}</a></li>
          ))}
          <li><a href="https://github.com/grebmann1/zana" target="_blank" rel="noopener noreferrer" class="btn-primary !py-2 !px-4 text-sm">GitHub</a></li>
        </ul>
      </div>
    </details>
  </div>
</header>
