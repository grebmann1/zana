---
interface Props {
  title: string;
  body: string;
  glyph: 'orchestrate' | 'deliberate' | 'automate';
}
const { title, body, glyph } = Astro.props;
---
<article class="relative rounded-2xl border border-forest/10 bg-cream/70 p-7 shadow-sm transition hover:shadow-md hover:-translate-y-0.5">
  <span class="absolute -top-3 left-6 rounded-full bg-parchment px-3 py-1 text-[10px] uppercase tracking-widest text-gold">{glyph}</span>
  <div class="mt-2 mb-5 text-gold">
    {glyph === 'orchestrate' && (
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <circle cx="20" cy="20" r="6" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="6" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="34" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="6" cy="30" r="3" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="34" cy="30" r="3" stroke="currentColor" stroke-width="1.5"/>
        <path d="M9 11 L15 17 M31 11 L25 17 M9 29 L15 23 M31 29 L25 23" stroke="currentColor" stroke-width="1" />
      </svg>
    )}
    {glyph === 'deliberate' && (
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <path d="M8 22 V12 a3 3 0 0 1 3 -3 H29 a3 3 0 0 1 3 3 V22 a3 3 0 0 1 -3 3 H17 L11 30 V25 H11 a3 3 0 0 1 -3 -3 Z" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="15" cy="17" r="1.4" fill="currentColor"/>
        <circle cx="20" cy="17" r="1.4" fill="currentColor"/>
        <circle cx="25" cy="17" r="1.4" fill="currentColor"/>
      </svg>
    )}
    {glyph === 'automate' && (
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="1.5"/>
        <path d="M20 12 V20 L26 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 8 L34 6 M6 32 L10 34" stroke="currentColor" stroke-width="1"/>
      </svg>
    )}
  </div>
  <h3 class="font-display text-2xl text-forest">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-moss">{body}</p>
</article>
