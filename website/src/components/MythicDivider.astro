---
// A small ornamental divider — gold linework, vaguely runic.
---
<div class="flex items-center gap-4 text-gold" aria-hidden="true">
  <span class="h-px flex-1 bg-gradient-to-r from-transparent via-gold/60 to-gold/30"></span>
  <svg width="60" height="14" viewBox="0 0 60 14" fill="none">
    <path d="M2 7 H22" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
    <circle cx="30" cy="7" r="2.5" stroke="currentColor" stroke-width="1" fill="none" />
    <path d="M30 1 L30 13 M24 7 L36 7" stroke="currentColor" stroke-width="0.6" stroke-linecap="round"/>
    <path d="M38 7 H58" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  </svg>
  <span class="h-px flex-1 bg-gradient-to-l from-transparent via-gold/60 to-gold/30"></span>
</div>
