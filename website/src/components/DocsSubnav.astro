---
import { link, stripBase } from '../lib/url';
const links = [
  { href: '/docs/', label: 'Quickstart', match: /^\/docs\/?$/ },
  { href: '/docs/recipes/', label: 'Recipes', match: /^\/docs\/recipes(\/|$)/ },
  { href: '/docs/concepts/', label: 'Concepts', match: /^\/docs\/concepts(\/|$)/ },
  { href: '/docs/skills/', label: 'Skills', match: /^\/docs\/skills(\/|$)/ },
  { href: '/docs/commands/', label: 'Commands', match: /^\/docs\/commands(\/|$)/ },
  { href: '/docs/cli/', label: 'CLI', match: /^\/docs\/cli(\/|$)/ },
];
const path = stripBase(Astro.url.pathname);
---

<nav aria-label="Docs sections" class="border-b border-forest/10 bg-parchment/30">
  <div class="container-zana flex flex-wrap items-center gap-x-6 gap-y-2 py-3 text-sm">
    <span class="text-xs uppercase tracking-widest text-gold">Docs</span>
    {links.map((l) => (
      <a
        href={link(l.href)}
        class:list={[
          'transition',
          l.match.test(path) ? 'text-forest font-semibold' : 'text-moss hover:text-forest',
        ]}
      >
        {l.label}
      </a>
    ))}
  </div>
</nav>
